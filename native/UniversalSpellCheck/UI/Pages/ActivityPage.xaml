<Page x:Class="UniversalSpellCheck.UI.Pages.ActivityPage"
      x:ClassModifier="internal"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource Canvas}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles.xaml"/>
                <ResourceDictionary Source="../Components.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="32,24,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Style="{StaticResource DisplayHeader}"
                   Text="Today"
                   Margin="0,0,0,24"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Activity feed card -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DiffStack">
                        <!-- Sample diff row — repeat for each correction.
                             Replace this with ItemsControl bound to log entries
                             from DiagnosticsLogger when wiring data. -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Style="{StaticResource MonoSmall}"
                                       Text="10:24 AM"
                                       Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Style="{StaticResource MonoSmall}"
                                       Text="gpt-4.1"
                                       Margin="0,0,0,4"/>

                            <Border Grid.Row="1" Grid.ColumnSpan="2"
                                    Style="{StaticResource DiffMinusLine}">
                                <TextBlock FontFamily="{StaticResource FontMono}"
                                           FontSize="12"
                                           Foreground="{StaticResource DiffMinusText}"
                                           Text="− their going to the store"/>
                            </Border>
                            <Border Grid.Row="2" Grid.ColumnSpan="2"
                                    Style="{StaticResource DiffPlusLine}">
                                <TextBlock FontFamily="{StaticResource FontMono}"
                                           FontSize="12"
                                           Foreground="{StaticResource DiffPlusText}"
                                           Text="+ they&#x27;re going to the store"/>
                            </Border>
                        </Grid>

                        <!-- Empty state placeholder shown when no entries.
                             Toggle visibility based on data. -->
                        <TextBlock x:Name="EmptyState"
                                   Style="{StaticResource BodyMuted}"
                                   Text="No spell checks yet today. Press your hotkey to get started."
                                   HorizontalAlignment="Center"
                                   Margin="0,48,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Stats card -->
            <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0">
                        <TextBlock x:Name="StatChecks" Style="{StaticResource DisplayStat}" Text="0"/>
                        <TextBlock Style="{StaticResource Caption}" Text="CHECKS" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="0">
                        <TextBlock x:Name="StatCorrections" Style="{StaticResource DisplayStat}" Text="0"/>
                        <TextBlock Style="{StaticResource Caption}" Text="CORRECTIONS" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="2">
                        <TextBlock x:Name="StatAccuracy" Style="{StaticResource DisplayStat}" Text="—"/>
                        <TextBlock Style="{StaticResource Caption}" Text="ACCURACY" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="2">
                        <TextBlock x:Name="StatStreak"
                                   Style="{StaticResource DisplayStat}"
                                   Foreground="{StaticResource Accent}"
                                   Text="0"/>
                        <TextBlock Style="{StaticResource Caption}" Text="DAY STREAK" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>

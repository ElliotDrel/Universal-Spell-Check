<Page x:Class="UniversalSpellCheck.UI.Pages.ActivityPage"
      x:ClassModifier="internal"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource Canvas}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/UniversalSpellCheck;component/UI/Styles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/UniversalSpellCheck;component/UI/Components.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="32,24,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Style="{StaticResource DisplayHeader}"
                       Text="Activity"
                       VerticalAlignment="Center"/>
            <Button Style="{StaticResource GhostButton}"
                    Content="↻ Refresh"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="RefreshButton_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Activity feed card -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <DockPanel>
                    <!-- Date range for currently loaded history -->
                    <TextBlock x:Name="FeedRangeLabel"
                               DockPanel.Dock="Top"
                               Style="{StaticResource BodyMuted}"
                               Margin="0,0,0,16"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="DiffStack">
                            <TextBlock x:Name="EmptyState"
                                       Style="{StaticResource BodyMuted}"
                                       Text="No spell checks in the last 7 days. Press your hotkey to get started."
                                       HorizontalAlignment="Center"
                                       Margin="0,48,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Stats card: all-time counts -->
            <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}"
                               Text="ALL TIME"
                               Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Grid.Row="0">
                            <TextBlock x:Name="StatChecks" Style="{StaticResource DisplayStat}" Text="0"/>
                            <TextBlock Style="{StaticResource Caption}" Text="CHECKS" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="0">
                            <TextBlock x:Name="StatCorrections" Style="{StaticResource DisplayStat}" Text="0"/>
                            <TextBlock Style="{StaticResource Caption}" Text="CORRECTIONS" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="2">
                            <TextBlock x:Name="StatAccuracy" Style="{StaticResource DisplayStat}" Text="—"/>
                            <TextBlock Style="{StaticResource Caption}" Text="ACCURACY" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="2">
                            <TextBlock x:Name="StatStreak"
                                       Style="{StaticResource DisplayStat}"
                                       Foreground="{StaticResource Accent}"
                                       Text="0"/>
                            <TextBlock Style="{StaticResource Caption}" Text="DAY STREAK" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

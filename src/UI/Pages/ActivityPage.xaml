<Page x:Class="UniversalSpellCheck.UI.Pages.ActivityPage"
      x:ClassModifier="internal"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:UniversalSpellCheck.UI"
      Background="{DynamicResource Canvas}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/UniversalSpellCheck;component/UI/Styles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/UniversalSpellCheck;component/UI/Components.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Storyboard x:Key="FeedLoadingSpinnerStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="FeedLoadingSpinnerRotate"
                                  Storyboard.TargetProperty="Angle"
                                  From="0"
                                  To="360"
                                  Duration="0:0:0.75"/>
            </Storyboard>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="32,24,64,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Style="{StaticResource DisplayHeader}"
                       Text="Activity"
                       VerticalAlignment="Center"/>
            <Button Style="{StaticResource GhostButton}"
                    Content="↻ Refresh"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="RefreshButton_Click"/>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,1"
                Padding="0,14"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="StatChecks" Style="{StaticResource DisplayStat}" Text="0"/>
                    <TextBlock Style="{StaticResource Caption}" Text="CHECKS" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" Background="{StaticResource Border}" Margin="0,4"/>

                <StackPanel Grid.Column="2">
                    <TextBlock x:Name="StatCorrections" Style="{StaticResource DisplayStat}" Text="0"/>
                    <TextBlock Style="{StaticResource Caption}" Text="CORRECTIONS" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="3" Background="{StaticResource Border}" Margin="0,4"/>

                <StackPanel Grid.Column="4">
                    <TextBlock x:Name="StatAccuracy" Style="{StaticResource DisplayStat}" Text="—"/>
                    <TextBlock Style="{StaticResource Caption}" Text="ACCURACY" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="5" Background="{StaticResource Border}" Margin="0,4"/>

                <StackPanel Grid.Column="6">
                    <TextBlock x:Name="StatStreak"
                               Style="{StaticResource DisplayStat}"
                               Foreground="{StaticResource Accent}"
                               Text="0"/>
                    <TextBlock Style="{StaticResource Caption}" Text="DAY STREAK" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2">
            <ui:SmoothScrollViewer x:Name="FeedScrollViewer">
                <StackPanel x:Name="DiffStack">
                    <TextBlock x:Name="EmptyState"
                               Style="{StaticResource BodyMuted}"
                               Text="No spell checks yet. Press your hotkey to get started."
                               HorizontalAlignment="Center"
                               Margin="0,48,0,0"
                               Visibility="Collapsed"/>
                    <StackPanel x:Name="FeedItems"/>
                    <StackPanel x:Name="LoadingIndicator"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,24"
                                Visibility="Collapsed">
                        <Grid Width="18"
                              Height="18"
                              Margin="0,0,0,8"
                              HorizontalAlignment="Center">
                            <Ellipse Width="18"
                                     Height="18"
                                     Stroke="{StaticResource Border}"
                                     StrokeThickness="2"/>
                            <Ellipse Width="18"
                                     Height="18"
                                     Stroke="{StaticResource TextMuted}"
                                     StrokeThickness="2"
                                     StrokeDashArray="2.5 20"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="FeedLoadingSpinnerRotate"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                        <TextBlock Style="{StaticResource BodyMuted}"
                                   Text="Loading earlier…"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ui:SmoothScrollViewer>
        </DockPanel>
    </Grid>
</Page>
